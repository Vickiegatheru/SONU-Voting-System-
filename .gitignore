# --- Compiled Executables ---
# Ignore Windows executables generated by gcc
*.exe
# Ignore specific compiled program names
sonu_portal
seed
sonu_voting

# --- Build Artifacts ---
# Ignore object files
*.o
*.obj

# --- Election Data ---
# It is best practice not to upload personal test data to GitHub
data/*.dat
data/*.csv

# --- IDE and System Files ---
# Ignore VS Code settings and workspace files
.vscode/
# Ignore MacOS system files if you ever switch
.DS_Store

# --- OneDrive Temporary Files ---
# Since you are working in a OneDrive folder
~$*ss
.lock